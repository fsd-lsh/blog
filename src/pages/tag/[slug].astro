---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteMeta } from '../../site.config';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const seen = new Set<string>();
  return siteMeta.tags
    .filter((tag) => {
      if (seen.has(tag.slug)) return false;
      seen.add(tag.slug);
      return true;
    })
    .map((tag) => ({
      params: { slug: tag.slug },
      props: {
        tag,
        posts: posts
          .filter((p) => p.data.tags.some((t) => t === tag.name))
          .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
      },
    }));
}

const { tag, posts } = Astro.props;

function formatDate(d: Date) {
  return d.toISOString().slice(0, 10);
}
---

<BaseLayout title={`标签 ${tag.name} 下的文章`}>
  <header class="blog-post-page-title blog-search-page-title">
    <h4>
      标签 <span class="archive-page-keyword">{tag.name}</span> 下的文章
    </h4>
  </header>
  <div class="blog-main-post blog-post-page-box">
    {
      posts.map((post) => (
        <article class="blog-post-block">
          <div class="blog-post-block-padding">
            <a href={`/archives/${post.data.typechoCid}.html`}>{post.data.title}</a>
            <section set:html={post.data.description || ''} />
            <footer>
              <time datetime={post.data.date.toISOString()}>
                <i class="fa fa-clock-o" />
                {formatDate(post.data.date)}
              </time>
            </footer>
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>
