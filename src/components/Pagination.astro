---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;

function pageHref(p: number) {
  if (p <= 1) return basePath;
  return `${basePath}page/${p}.html`;
}

// Generate page numbers to display (show up to 7 pages with ellipsis)
function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  const pages: (number | '...')[] = [];
  // Always show first page
  pages.push(1);
  if (current > 3) pages.push('...');
  // Pages around current
  const start = Math.max(2, current - 1);
  const end = Math.min(total - 1, current + 1);
  for (let i = start; i <= end; i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push('...');
  // Always show last page
  pages.push(total);
  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
---

{
  totalPages > 1 && (
    <nav class="blog-pagination pagination-tl">
      {currentPage > 1 ? (
        <a href={pageHref(currentPage - 1)} class="prev" aria-label="上一页">
          <i class="fa fa-angle-left" />
        </a>
      ) : (
        <span class="prev disabled">
          <i class="fa fa-angle-left" />
        </span>
      )}
      {pageNumbers.map((p) =>
        p === '...' ? (
          <span class="space">...</span>
        ) : p === currentPage ? (
          <span class="current">{p}</span>
        ) : (
          <a href={pageHref(p)}>{p}</a>
        )
      )}
      {currentPage < totalPages ? (
        <a href={pageHref(currentPage + 1)} class="next" aria-label="下一页">
          <i class="fa fa-angle-right" />
        </a>
      ) : (
        <span class="next disabled">
          <i class="fa fa-angle-right" />
        </span>
      )}
    </nav>
  )
}
