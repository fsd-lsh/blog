---
interface Props {
  permalink: string;
}

const { permalink } = Astro.props;
import { siteConfig } from '../site.config';
const fullUrl = new URL(permalink, siteConfig.siteUrl).href;
---

<div class="modal fade" id="post-qrcode-content" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-sm" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">文章二维码</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="row post-qrcode-content" style="text-align:center;">
          <div id="post-qrcode-target" data-url={fullUrl}></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">关闭</button>
      </div>
    </div>
  </div>
</div>

<script>
  import '../scripts/post-qrcode.ts';
</script>
